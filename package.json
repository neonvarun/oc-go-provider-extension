{
  "name": "opencode-go-vscode-chat",
  "displayName": "OpenCode Go Chat Provider for VS Code",
  "description": "Integrates OpenCode Go models (GLM-5/5.1, Kimi K2.5/K2.6, MiMo-V2/V2.5, MiniMax M2.5/M2.7, Qwen3.5/3.6 Plus, DeepSeek V4 Flash/Pro) into VS Code Copilot Chat with tool calling, vision, and thinking/reasoning levels",
  "version": "0.7.0",
  "publisher": "Ryosuke-Asano",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ryosuke-Asano/oc-go-provider-extension"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ai",
    "chat",
    "copilot",
    "opencode",
    "opencode-go",
    "glm",
    "kimi",
    "mimo",
    "minimax",
    "qwen",
    "deepseek",
    "llm"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [
    "chatProvider"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "opencode-go",
        "displayName": "OpenCode Go",
        "managementCommand": "opencode-go.manage"
      }
    ],
    "languageModelTools": [
      {
        "name": "opencode_go_analyze_image",
        "displayName": "Analyze Image with OpenCode Go Vision",
        "modelDescription": "Analyze an image using OpenCode Go Vision model. Use this tool when you need to understand or describe the content of an image, extract text from images (OCR), or answer questions about visual content.",
        "icon": "$(eye)"
      }
    ],
    "commands": [
      {
        "command": "opencode-go.manage",
        "title": "Manage OpenCode Go Provider",
        "category": "OpenCode Go"
      }
    ],
    "configuration": {
      "title": "OpenCode Go",
      "properties": {}
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "download-api": "dts dev",
    "postdownload-api": "dts main",
    "postinstall": "npm run download-api",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "package": "vsce package --no-yarn",
    "publish": "vsce publish --no-yarn"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.1.0",
    "@types/vscode": "^1.104.0",
    "@vscode/dts": "^0.4.1",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.1"
  }
}